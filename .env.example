APP__SERVER__HOST=0.0.0.0
APP__SERVER__PORT=8080

APP__BACKEND__BASE_URL=http://localhost:8080
APP__FRONTEND__BASE_URL=http://localhost:3000

APP__KEYCLOAK__ISSUER_URL=http://localhost:8081/realms/truegather
APP__KEYCLOAK__CLIENT_ID=truegather-backend

APP__AUTH__COOKIE_NAME=tg_session
APP__AUTH__COOKIE_SECURE=false

# SMTP (optionnel — si non configuré, les emails sont ignorés)
APP__SMTP__HOST=smtp.gmail.com
APP__SMTP__PORT=587
APP__SMTP__USERNAME=votre@gmail.com
APP__SMTP__PASSWORD=votre_app_password
APP__SMTP__FROM=TrueGather <votre@gmail.com>

RUST_LOG=info,truegather_backend=debug,tower_http=info
